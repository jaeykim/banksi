{
  "name": "banksi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "mcp": "npx tsx src/mcp/server.ts",
    "db:sqlite": "bash scripts/use-sqlite.sh && npx prisma generate",
    "db:postgres": "bash scripts/use-postgres.sh && npx prisma generate",
    "sdk:build": "cd packages/sdk && npm run build",
    "sdk:publish": "cd packages/sdk && npm publish --access public",
    "mcp:publish": "cd packages/mcp && npm publish --access public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@prisma/client": "^5.22.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.95.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "prisma": "^5.22.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tronweb": "^6.2.2",
    "tsx": "^4.21.0",
    "uuid": "^13.0.0",
    "viem": "^2.47.6",
    "wagmi": "^3.6.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
